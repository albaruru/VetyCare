<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Nombre de usuario y mascota -->
    <style name="Nombres">
        <item name="android:fontFamily">@font/tommy_soft_medium</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Texto informativo -->
    <style name="TextInformativo">
        <item name="android:fontFamily">@font/tommy_soft_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/Informativo</item>
    </style>

    <!-- Botones -->
    <style name="TextBotones">
        <item name="android:fontFamily">@font/tommy_soft_regular</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/Titulo</item>
    </style>

    <!-- Estilo base Negrita -->
    <style name="TextBaseNegrita">
        <item name="android:fontFamily">@font/tommy_soft_light</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/Base</item>
    </style>

    <!-- Estilo base -->
    <style name="TextBase">
        <item name="android:fontFamily">@font/tommy_soft_light</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/Base</item>
    </style>

    <!-- Subtitulo -->
    <style name="TextSubtitulo">
        <item name="android:fontFamily">@font/tommy_soft_regular</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/Subtitulo</item>
    </style>

    <!-- Título -->
    <style name="TextTitulo">
        <item name="android:fontFamily">@font/tommy_soft_medium</item>
        <item name="android:textSize">23sp</item>
        <item name="android:textColor">@color/Titulo</item>
    </style>

    <!-- App Name -->
    <style name="AppName">
        <item name="android:fontFamily">@font/tommy_soft_medium</item>
        <item name="android:textSize">50sp</item>
        <item name="android:textColor">@color/Titulo</item>
    </style>
    <style name="ShapeCircle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

</resources>
