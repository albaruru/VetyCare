<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_root"
    app:startDestination="@id/inicioContainerFragment">

    <fragment
        android:id="@+id/inicioContainerFragment"
        android:name="com.example.vetycare.ui.container.InicioContainerFragment"
        android:label="InicioContainerFragment"
        tools:layout="@layout/fragment_container_inicio" />

    <fragment
        android:id="@+id/usuarioContainerFragment"
        android:name="com.example.vetycare.ui.container.UsuarioContainerFragment"
        android:label="UsuarioContainerFragment"
        tools:layout="@layout/fragment_container_usuario" />

    <fragment
        android:id="@+id/mascotaContainerFragment"
        android:name="com.example.vetycare.ui.container.MascotaContainerFragment"
        android:label="MascotaContainerFragment"
        tools:layout="@layout/fragment_container_mascota" />

    <action
        android:id="@+id/action_inicioContainerFragment_to_usuarioContainerFragment"
        app:destination="@id/usuarioContainerFragment" />

    <action
        android:id="@+id/action_usuarioContainerFragment_to_inicioContainerFragment"
        app:destination="@id/inicioContainerFragment"
        app:popUpTo="@id/nav_graph_root"
        app:popUpToInclusive="false" />

    <action
        android:id="@+id/action_usuarioContainerFragment_to_mascotaContainerFragment"
        app:destination="@id/mascotaContainerFragment" />

    <action
        android:id="@+id/action_mascotaContainerFragment_to_usuarioContainerFragment"
        app:destination="@id/usuarioContainerFragment"
        app:popUpTo="@id/usuarioContainerFragment"
        app:popUpToInclusive="false" />

</navigation>