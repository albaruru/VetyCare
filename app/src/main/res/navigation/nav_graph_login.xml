<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_login"
    app:startDestination="@+id/InicioFragment">

    <!-- FRAGMENTS -->
    <fragment
        android:id="@+id/InicioFragment"
        android:name="com.example.vetycare.ui.fragment.inicio.InicioPrincipalFragment"
        android:label="@string/fragment_inicio_label"
        tools:layout="@layout/fragment_inicio_principal"
        >
        <action
            android:id="@+id/action_InicioFragment_to_RegUsuarioFragment"
            app:destination="@id/RegUsuarioFragment" />
        <action
            android:id="@+id/action_InicioFragment_to_RecPassFragment"
            app:destination="@id/RecPassFragment" />
    </fragment>
    <fragment
        android:id="@+id/RecPassFragment"
        android:name="com.example.vetycare.ui.fragment.inicio.InicioRecPassFragment"
        android:label="@string/fragment_rec_pass_label"
        tools:layout="@layout/fragment_inicio_rec_pass"
        >
        <action
            android:id="@+id/action_RecPassFragment_to_InicioFragment"
            app:destination="@id/InicioFragment" />
    </fragment>
    <fragment
        android:id="@+id/RegUsuarioFragment"
        android:name="com.example.vetycare.ui.fragment.inicio.InicioRegistroFragment"
        android:label="@string/fragment_reg_usuario_label"
        tools:layout="@layout/fragment_inicio_registro"
        >
        <action
            android:id="@+id/action_RegUsuarioFragment_to_confirmacionDialog"
            app:destination="@id/confirmacionDialog" />
        <action
            android:id="@+id/action_RegUsuarioFragment_to_cancelacionDialog"
            app:destination="@id/cancelacionDialog" />
    </fragment>

    <!-- DIALOGS -->
    <dialog
        android:id="@+id/confirmacionDialog"
        android:name="com.example.vetycare.ui.dialog.ConfirmacionDialog"
        android:label="ConfirmacionDialog" >
        <action
            android:id="@+id/action_confirmacionDialog_to_InicioFragment"
            app:destination="@id/InicioFragment" />
    </dialog>
    <dialog
        android:id="@+id/cancelacionDialog"
        android:name="com.example.vetycare.ui.dialog.CancelacionDialog"
        android:label="CancelacionDialog" >
        <action
            android:id="@+id/action_cancelacionDialog_to_InicioFragment"
            app:destination="@id/InicioFragment" />
    </dialog>
</navigation>