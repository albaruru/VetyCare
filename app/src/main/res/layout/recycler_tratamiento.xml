<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/background_cuadro_formulario"
    android:padding="12dp">
    <!-- TÍTULO -->
    <TextView
        android:id="@+id/tv_titulo"
        style="@style/TextSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/tratamiento_id"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- MEDICACIÓN -->
    <TextView
        android:id="@+id/tv_label_medicacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/tratamiento_label_medicacion_recycler"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_titulo"
        style="@style/TextBaseNegrita"/>

    <TextView
        android:id="@+id/tv_medicacion"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/background_cuadro_texto"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_label_medicacion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/TextBase" />

    <!-- FRECUENCIA -->
    <TextView
        android:id="@+id/tv_label_frecuencia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/tratamiento_label_frecuencia_recycler"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_medicacion"
        style="@style/TextBaseNegrita"/>

    <TextView
        android:id="@+id/tv_frecuencia"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/background_cuadro_texto"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_label_frecuencia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/TextBase" />

    <!-- BOTÓN -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_ver_mas"
        style="@style/TextBotones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/botones"
        android:text="@string/informe_btn_ver_mas"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
