<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/formulario"
    app:strokeColor="@color/formulario_borde"
    app:strokeWidth="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/tv_titulo"
            android:text="@string/tratamiento_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_ver_mas"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/TextSubtitulo"/>

        <!-- BOTÓN -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ver_mas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/botones"
            android:layout_marginTop="4dp"
            android:text="@string/tratamiento_btn_detalles"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/TextBotones"/>

        <!-- MEDICACIÓN -->
        <TextView
            android:id="@+id/tv_label_medicacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="15dp"
            android:text="@string/tratamiento_label_medicacion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo"
            style="@style/TextBaseNegrita"/>

        <TextView
            android:id="@+id/tv_medicacion"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:padding="8dp"
            android:textSize="14dp"
            android:gravity="center_vertical"
            android:background="@drawable/background_cuadro_texto"
            app:layout_constraintTop_toBottomOf="@id/tv_label_medicacion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextBase" />

        <!-- FRECUENCIA -->
        <TextView
            android:id="@+id/tv_label_frecuencia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="15dp"
            android:text="@string/tratamiento_label_frecuencia"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_medicacion"
            style="@style/TextBaseNegrita"/>

        <TextView
            android:id="@+id/tv_frecuencia"
            style="@style/TextBase"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:textSize="14dp"
            android:background="@drawable/background_cuadro_texto"
            android:gravity="center_vertical"
            android:padding="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_label_frecuencia" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>