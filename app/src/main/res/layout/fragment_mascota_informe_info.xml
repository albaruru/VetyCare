<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/content_mascotas">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="24dp"
        android:paddingHorizontal="24dp">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/tv_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/informe_id"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextTitulo"/>

        <!-- CONCEPTO -->
        <TextView
            android:id="@+id/tv_label_concepto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginStart="15dp"
            android:text="@string/informe_label_concepto"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/TextBaseNegrita" />

        <TextView
            android:id="@+id/tv_concepto"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:padding="8dp"
            android:paddingStart="15dp"
            android:gravity="center_vertical"
            android:background="@drawable/background_cuadro_texto"
            app:layout_constraintTop_toBottomOf="@id/tv_label_concepto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextBase"/>

        <!-- FECHA -->
        <TextView
            android:id="@+id/tv_label_fecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="15dp"
            android:text="@string/informe_label_fecha"
            app:layout_constraintTop_toBottomOf="@id/tv_concepto"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/TextBaseNegrita" />
        <TextView
            android:id="@+id/tv_fecha"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:padding="8dp"
            android:paddingStart="15dp"
            android:gravity="center_vertical"
            android:background="@drawable/background_cuadro_texto"
            app:layout_constraintTop_toBottomOf="@id/tv_label_fecha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextBase" />

        <!-- VALORACIÓN -->
        <TextView
            android:id="@+id/tv_label_valoracion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="15dp"
            android:text="@string/informe_label_valoracion"
            app:layout_constraintTop_toBottomOf="@id/tv_fecha"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/TextBaseNegrita" />
        <TextView
            android:id="@+id/tv_valoracion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:layout_marginTop="4dp"
            android:padding="8dp"
            android:paddingStart="15dp"
            android:gravity="center_vertical"
            android:background="@drawable/background_cuadro_texto"
            app:layout_constraintTop_toBottomOf="@id/tv_label_valoracion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextBase" />

        <!-- MEDICAMENTO -->
        <TextView
            android:id="@+id/tv_label_medicamento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="15dp"
            android:text="@string/informe_label_medicamento"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_valoracion"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/TextBaseNegrita" />
        <TextView
            android:id="@+id/tv_medicamento"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:padding="8dp"
            android:paddingStart="15dp"
            android:gravity="center_vertical"
            android:background="@drawable/background_cuadro_texto"
            app:layout_constraintTop_toBottomOf="@id/tv_label_medicamento"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextBase" />

        <!-- TRATAMIENTO -->
        <TextView
            android:id="@+id/tv_label_tratamiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="15dp"
            android:text="@string/informe_label_tratamiento"
            app:layout_constraintTop_toBottomOf="@id/tv_medicamento"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/TextBaseNegrita" />
        <TextView
            android:id="@+id/tv_tratamiento"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:padding="8dp"
            android:paddingStart="15dp"
            android:gravity="center_vertical"
            android:background="@drawable/background_cuadro_texto"
            app:layout_constraintTop_toBottomOf="@id/tv_label_tratamiento"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextBase" />

        <!-- IMPORTE -->
        <TextView
            android:id="@+id/tv_label_importe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="15dp"
            android:text="@string/informe_label_importe"
            app:layout_constraintTop_toBottomOf="@id/tv_tratamiento"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/TextBaseNegrita" />
        <TextView
            android:id="@+id/tv_importe"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:padding="8dp"
            android:paddingStart="15dp"
            android:gravity="center_vertical"
            android:background="@drawable/background_cuadro_texto"
            app:layout_constraintTop_toBottomOf="@id/tv_label_importe"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextBase" />

        <!-- VOLVER -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_volver"
            style="@style/TextBotones"
            android:layout_width="145dp"
            android:layout_height="45dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:layout_marginEnd="8dp"
            android:text="@string/volver"
            android:background="@drawable/boton_volver_cancelar"
            app:backgroundTint="@null"
            app:layout_constraintTop_toBottomOf="@id/tv_importe"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guia_central"/>


        <!-- VER TRATAMIENTO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ver_tratamiento"
            style="@style/TextBotones"
            android:layout_width="145dp"
            android:layout_height="45dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:layout_marginStart="8dp"
            android:text="@string/btn_tratamiento"
            android:background="@drawable/botones"
            app:backgroundTint="@null"
            app:layout_constraintTop_toBottomOf="@id/tv_importe"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/guia_central"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guia_central"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
