<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/background_cuadro_texto"
    android:padding="12dp">

    <!-- Foto de la mascota -->
    <ImageView
        android:id="@+id/iv_foto_mascota"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:background="@drawable/background_cuadro_texto"
        android:contentDescription="Foto mascota"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_camera"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guia_central"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Botón "Mascota" -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_mascota"
        style="@style/TextBaseNegrita"
        android:layout_width="243dp"
        android:layout_height="46dp"
        android:background="@drawable/botones"
        android:text="@string/item_mascota"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guia_central"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Separar foto del botón -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guia_central"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.26" />

</androidx.constraintlayout.widget.ConstraintLayout>


