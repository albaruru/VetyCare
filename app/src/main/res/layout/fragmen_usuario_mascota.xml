<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/content_main">

    <!-- HEADER: Foto dueño + Nombre + Logo -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="@color/content_main"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Foto del dueño -->
        <ImageView
            android:id="@+id/iv_foto_dueno"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/background_cuadro_texto"
            android:src="@android:drawable/ic_menu_camera"
            android:scaleType="centerCrop"
            android:padding="8dp"
            android:contentDescription="Foto de perfil"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Nombre del dueño -->
        <TextView
            android:id="@+id/tv_nombre_dueno"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Nombre_dueño"
            app:layout_constraintTop_toTopOf="@id/iv_foto_dueno"
            app:layout_constraintBottom_toBottomOf="@id/iv_foto_dueno"
            app:layout_constraintStart_toEndOf="@id/iv_foto_dueno"
            app:layout_constraintEnd_toStartOf="@id/iv_logo"
            style="@style/TextTitulo" />

        <!-- Logo empresa -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/background_cuadro_texto"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop"
            android:padding="4dp"
            android:contentDescription="Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Divider -->
    <View
        android:id="@+id/divider_header"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/menu"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader" />

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/tv_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="PERFIL MASCOTAS"
        app:layout_constraintTop_toBottomOf="@id/divider_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/TextSubtitulo" />

    <!-- Divider bajo título -->
    <View
        android:id="@+id/divider_titulo"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="@color/menu"
        app:layout_constraintTop_toBottomOf="@id/tv_titulo" />

    <!-- RECYCLERVIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMascotas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/divider_titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>


