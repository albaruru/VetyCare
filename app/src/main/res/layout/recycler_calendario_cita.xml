<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/background_cuadro_formulario"
    android:padding="16dp">

    <!-- Mascota -->
    <TextView
        android:id="@+id/tv_label_mascota"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:text="@string/usuario_cldr_cita_mascota"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBaseNegrita"/>
    <TextView
        android:id="@+id/tv_mascota"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/background_cuadro_texto"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_label_mascota"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBase"/>

    <!-- Clínica -->
    <TextView
        android:id="@+id/tv_label_clinica"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="15dp"
        android:text="@string/usuario_cldr_cita_clinica"
        app:layout_constraintTop_toBottomOf="@id/tv_mascota"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBaseNegrita"/>
    <TextView
        android:id="@+id/tv_clinica"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/background_cuadro_texto"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_label_clinica"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBase"/>

    <!-- Tipo -->
    <TextView
        android:id="@+id/tv_label_tipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="15dp"
        android:text="@string/usuario_cldr_cita_tipo"
        app:layout_constraintTop_toBottomOf="@id/tv_clinica"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBaseNegrita"/>
    <TextView
        android:id="@+id/tv_tipo"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/background_cuadro_texto"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_label_tipo"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBase"/>

    <!-- Motivo -->
    <TextView
        android:id="@+id/tv_label_motivo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="15dp"
        android:text="@string/usuario_cldr_cita_motivo"
        app:layout_constraintTop_toBottomOf="@id/tv_tipo"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBaseNegrita"/>
    <TextView
        android:id="@+id/tv_motivo"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/background_cuadro_texto"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_label_motivo"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBase"/>

    <!-- Fecha -->
    <TextView
        android:id="@+id/tv_label_fecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="15dp"
        android:text="@string/usuario_cldr_cita_fecha"
        app:layout_constraintTop_toBottomOf="@id/tv_motivo"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBaseNegrita"/>
    <TextView
        android:id="@+id/tv_fecha"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/background_cuadro_texto"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_label_fecha"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/TextBase"/>

</androidx.constraintlayout.widget.ConstraintLayout>