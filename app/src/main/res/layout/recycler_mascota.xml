<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/formulario"
    app:strokeColor="@color/formulario_borde"
    app:strokeWidth="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- FOTO DE LA MASCOTA -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_foto_mascota"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:background="@drawable/background_cuadro_texto"
            android:src="@android:drawable/ic_menu_camera"
            app:shapeAppearanceOverlay="@style/ShapeCircle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- BOTÓN - "Mascota" -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mascota"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/botones"
            android:text="@string/item_mascota"
            app:backgroundTint="@null"
            app:layout_constraintStart_toEndOf="@id/iv_foto_mascota"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_foto_mascota"
            app:layout_constraintBottom_toBottomOf="@id/iv_foto_mascota"
            style="@style/TextBotones"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>