<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/content_usuario">

    <!-- NestedScrollView solo admite UN hijo directo. To.do va dentro de este ConstraintLayout. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp">
        <!--TÍTULO -->
        <TextView
            android:id="@+id/tv_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="CALENDARIO"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/TextTitulo"/>
        <!-- SELECTOR MENSUAL / SEMANAL -->
        <RadioGroup
            android:id="@+id/rgVistaCalendario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <RadioButton
                android:id="@+id/rbMensual"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/usuario_calendario_btnMensual"
                android:checked="true"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:background="@drawable/botones"
                style="@style/TextBotones" />
            <RadioButton
                android:id="@+id/rbSemanal"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="@string/usuario_calendario_btnSemanal"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:background="@drawable/boton_volver_cancelar"
                style="@style/TextBotones" />
        </RadioGroup>

        <!-- CALENDARIO-->
        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="8dp"
            app:layout_constraintTop_toBottomOf="@id/rgVistaCalendario"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/TextBase"
            />

        <!--LEYENDA DE COLORES-->
        <LinearLayout
            android:id="@+id/layoutLeyenda"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/background_cuadro_texto"
            android:padding="10dp"
            app:layout_constraintTop_toBottomOf="@id/calendarView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@color/Vacunacion" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/usuario_calendario_Vacunación"
                    style="@style/TextBase" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@color/Revisión" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/usuario_calendario_Revisión"
                    style="@style/TextBase" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@color/Consulta" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/usuario_calendario_Consulta"
                    style="@style/TextBase" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@color/Pruebas" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/usuario_calendario_Pruebas"
                    style="@style/TextBase" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@color/Medicamentos" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/usuario_calendario_medicamentos"
                    style="@style/TextBase" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>