<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Capa sombra (detrás) -->
    <item
        android:left="2dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/botones_claros_sombra" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Fondo principal (encima) -->
    <item
        android:bottom="3dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/botones_claros" />
            <corners android:radius="20dp" />
            <stroke
                android:width="2dp"
                android:color="@color/botones_claros_bordes" />
        </shape>
    </item>

</layer-list>