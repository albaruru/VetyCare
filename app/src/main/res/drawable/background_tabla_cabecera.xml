<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/formulario" />
        </shape>
    </item>
    <!-- Borde solo arriba -->
    <item
        android:bottom="-2dp"
        android:left="-2dp"
        android:right="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="@color/formulario_borde" />
        </shape>
    </item>
</layer-list>