<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Capa sombra -->
    <item
        android:left="3dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/formulario_sombra" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Fondo principal-->
    <item
        android:bottom="4dp"
        android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/formulario" />
            <corners android:radius="20dp" />
            <stroke
                android:width="2dp"
                android:color="@color/formulario_borde" />
        </shape>
    </item>

</layer-list>
